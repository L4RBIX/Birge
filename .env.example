# ============================================================
# Birge — Environment Variables Example
# Copy this file to .env.local and fill in your values.
# DO NOT commit real secrets to version control.
# ============================================================

# ────────────────────────────────────────────────────────────
# Live Hackathon Demo
# ────────────────────────────────────────────────────────────

# Optional LAN URL override for the projector QR on /deal/demo.
# Example for phone testing on the same Wi-Fi:
#   npm run dev -- --hostname 0.0.0.0
#   NEXT_PUBLIC_DEMO_BASE_URL=http://192.168.0.141:3000
NEXT_PUBLIC_DEMO_BASE_URL=

# ────────────────────────────────────────────────────────────
# Level 2 — Telecom Identity Layer
# ────────────────────────────────────────────────────────────

# Provider to use: mock | gsma | vonage | custom
# "mock" is the default and never requires credentials.
# Switch to "gsma", "vonage", or "custom" for real SIM/number verification.
TELECOM_IDENTITY_PROVIDER=mock

# Country code (ISO 3166-1 alpha-2) for this deployment
TELECOM_COUNTRY=KZ

# Operator name hint (used in responses when the provider doesn't return one)
TELECOM_OPERATOR_HINT=Beeline

# Set to "false" to disable dev-mode and require real credentials.
# In dev-mode the mock provider returns a clearly labeled "verified"
# result without making any real network calls.
TELECOM_DEV_MODE=true

# ── GSMA Open Gateway / CAMARA ───────────────────────────────
# Required when TELECOM_IDENTITY_PROVIDER=gsma
TELECOM_NUMBER_VERIFY_URL=
TELECOM_CLIENT_ID=
TELECOM_CLIENT_SECRET=

# Optional: SIM swap risk endpoint
TELECOM_SIM_SWAP_URL=

# ── Vonage (Silent Auth / Verify v2) ─────────────────────────
# Required when TELECOM_IDENTITY_PROVIDER=vonage
TELECOM_API_KEY=
TELECOM_API_SECRET=

# ── Custom / Generic Operator ────────────────────────────────
# Required when TELECOM_IDENTITY_PROVIDER=custom
# TELECOM_NUMBER_VERIFY_URL (shared with gsma above)
# TELECOM_SIM_SWAP_URL     (shared with gsma above)
# At least one of: TELECOM_API_KEY, TELECOM_CLIENT_ID

# ── Webhook / Callback security ──────────────────────────────
TELECOM_REDIRECT_URI=
TELECOM_CALLBACK_SECRET=

# ────────────────────────────────────────────────────────────
# SMS OTP Verification Layer
# Live phone verification works now via SMS OTP.
# SIM/eSIM silent Network API is production-ready and can replace
# OTP once operator credentials are available.
# ────────────────────────────────────────────────────────────

# OTP provider to use: mock | twilio | vonage | custom
# "mock" is the default — uses dev-mode code 000000 when TELECOM_DEV_MODE=true.
TELECOM_OTP_PROVIDER=mock

# Set to "true" when TELECOM_OTP_PROVIDER is twilio, vonage, or custom.
# For a real-SMS-only QA run, also set TELECOM_DEV_MODE=false so mock fallback
# is visibly disabled.
TELECOM_OTP_ENABLED=false

# Quick activation examples:
# Twilio:
#   TELECOM_OTP_PROVIDER=twilio
#   TELECOM_OTP_ENABLED=true
#   TWILIO_ACCOUNT_SID=AC...
#   TWILIO_AUTH_TOKEN=...
#   TWILIO_VERIFY_SERVICE_SID=VA...
# Vonage:
#   TELECOM_OTP_PROVIDER=vonage
#   TELECOM_OTP_ENABLED=true
#   VONAGE_API_KEY=...
#   VONAGE_API_SECRET=...
# Custom:
#   TELECOM_OTP_PROVIDER=custom
#   TELECOM_OTP_ENABLED=true
#   CUSTOM_OTP_SEND_URL=https://...
#   CUSTOM_OTP_CHECK_URL=https://...
#   CUSTOM_OTP_API_KEY=...

# ── Twilio Verify v2 ─────────────────────────────────────────
# Required when TELECOM_OTP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ── Vonage Verify (legacy JSON API) ──────────────────────────
# Required when TELECOM_OTP_PROVIDER=vonage
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_BRAND_NAME=Birge

# ── Custom / Generic OTP Provider ────────────────────────────
# Required when TELECOM_OTP_PROVIDER=custom
CUSTOM_OTP_SEND_URL=
CUSTOM_OTP_CHECK_URL=
# Optional: sent as x-api-key when present
CUSTOM_OTP_API_KEY=
